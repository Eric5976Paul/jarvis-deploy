# jarvis-deploy configuration file
# Copy this file to jarvis.yml and adjust values for your project.

# Name of the Spring Boot application (required)
appName: my-spring-app

# Target deployment environment (default: "default")
environment: production

# Path to the built JAR artifact relative to project root (required)
artifactPath: target/my-spring-app-1.0.0.jar

# Directory on the target host where releases are stored
# Defaults to /opt/jarvis/deployments/<appName>
deployDir: /opt/apps/my-spring-app

# Number of previous releases to keep for rollback (default: 5)
maxRollbackVersions: 5

# Optional environment variables injected at runtime
envVars:
  SPRING_PROFILES_ACTIVE: production
  SERVER_PORT: "8080"
  DB_HOST: db.internal
